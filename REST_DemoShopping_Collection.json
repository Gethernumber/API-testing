        {
          "name": "Поиск по производителю",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Получаем список производителей из переменной окружения\r",
                  "let manufacturers = JSON.parse(pm.environment.get(\"manufacturerList\"));\r",
                  "\r",
                  "// Получаем текущий индекс\r",
                  "let index = parseInt(pm.environment.get(\"manufacturerIndex\"));\r",
                  "\r",
                  "// Берём производителя по индексу\r",
                  "let currentManufacturer = manufacturers[index];\r",
                  "\r",
                  "// Сохраняем текущего производителя в переменную для использования в URL\r",
                  "pm.environment.set(\"manufacturer\", currentManufacturer);\r",
                  "\r",
                  "// Логируем для отладки\r",
                  "console.log(\"Тестируем производителя:\", currentManufacturer);\r",
                  "\r",
                  "// Увеличиваем индекс для следующей итерации\r",
                  "index = (index + 1) % manufacturers.length;\r",
                  "pm.environment.set(\"manufacturerIndex\", index);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Статус 200 OK\", function () {\r",
                  "    pm.expect(pm.response.code).to.eql(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Все товары принадлежат выбранному производителю\", function () {\r",
                  "    let responseJson = pm.response.json();\r",
                  "    let manufacturer = pm.environment.get(\"manufacturer\");\r",
                  "\r",
                  "    // Проверяем, что каждый товар имеет поле manufacturer равное выбранному производителю\r",
                  "    responseJson.forEach(product => {\r",
                  "        pm.expect(product.manufacturer).to.eql(manufacturer);\r",
                  "    });\r",
                  "});\r",
                  "\r",
                  "// Чистый лог для консоли\r",
                  "console.log(`✅ Производитель ${pm.environment.get(\"manufacturer\")} проверен`);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
