        {
          "name": "Добавить новый товар",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// Получаем ответ сервера как обычный текст\r",
                  "var text = pm.response.text();\r",
                  "\r",
                  "// Делим строку по \"ID:\" и берём часть после него\r",
                  "// ?. — защита от ошибки, если \"ID:\" не найден\r",
                  "var productId = text.split(\"ID:\")[1]?.trim();\r",
                  "\r",
                  "// Если ID не удалось получить — логируем ошибку и выходим\r",
                  "if (!productId) {\r",
                  "    console.log(\"Не удалось извлечь ID из ответа:\", text);\r",
                  "    return;\r",
                  "}\r",
                  "\r",
                  "// Сохраняем ID продукта в переменную окружения Postman\r",
                  "pm.environment.set(\"product_id\", productId);\r",
                  "\r",
                  "// Проверяем, что всё сработало\r",
                  "console.log(\"ID добавленного товара:\", productId);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"name\": \"Huawei Phone 26\",\r\n    \"description\": \"Описание для Huawei Phone 26\",\r\n    \"price\": 556.00,\r\n    \"category\": \"Phones\",\r\n    \"manufacturer\": \"Huawei\",\r\n    \"imageUrl\": \"/images/phone.webp\",\r\n    \"freeShipping\": true\r\n}",
