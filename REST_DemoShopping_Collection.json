        {
          "name": "Фильтрация товаров",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "//Объявляем переменную randomCategory с рандомными значениями\r",
                  "const categoryList = [\"Watches\", \"Phones\", \"Laptops\"];\r",
                  "\r",
                  "const randomCategory = categoryList[\r",
                  "    Math.floor(Math.random() * categoryList.length)\r",
                  "];\r",
                  "\r",
                  "pm.environment.set(\"randomCategory\", randomCategory);\r",
                  "\r",
                  "//Объявляем переменную randomManufacturer с рандомными значениями\r",
                  "const manufacturerList = [\"Samsung\", \"Apple\", \"Xiaomi\", \"Huawei\"];\r",
                  "\r",
                  "const randomManufacturer = manufacturerList[\r",
                  "    Math.floor(Math.random() * manufacturerList.length)\r",
                  "];\r",
                  "\r",
                  "pm.environment.set(\"randomManufacturer\", randomManufacturer);\r",
                  "\r",
                  "//Объявляем переменную randomShipping с рандомными значениями\r",
                  "const freeShipping = [true, false];\r",
                  "\r",
                  "const randomShipping = freeShipping[\r",
                  "    Math.floor(Math.random() * freeShipping.length)\r",
                  "];\r",
                  "\r",
                  "pm.environment.set(\"randomShipping\", randomShipping);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Статус 200 OK\", function () {\r",
                  "    pm.expect(pm.response.code).to.eql(200);\r",
                  "});\r",
                  "\r",
                  "const contentLength = Number(pm.response.headers.get(\"Content-Length\"));\r",
                  "\r",
                  "if (contentLength <= 2) {\r",
                  "    console.log(\"По заданным параметрам товары отсутствуют\");\r",
                  "} else {\r",
                  "    console.log(\"✅ Один или несколько товаров соответствуют заданным параметрам\");\r",
                  "}\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
