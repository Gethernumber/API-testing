        {
          "name": "Поиск товаров по категории",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Получаем список категорий из переменной окружения\r",
                  "let categories = JSON.parse(pm.environment.get(\"categoryList\"));\r",
                  "\r",
                  "// Получаем текущий индекс\r",
                  "let index = parseInt(pm.environment.get(\"categoryIndex\"));\r",
                  "\r",
                  "// Берём категорию по индексу\r",
                  "let currentCategory = categories[index];\r",
                  "\r",
                  "// Сохраняем текущую категорию в переменную для использования в URL\r",
                  "pm.environment.set(\"category\", currentCategory);\r",
                  "\r",
                  "// Логируем для отладки\r",
                  "console.log(\"Тестируем категорию:\", currentCategory);\r",
                  "\r",
                  "// Увеличиваем индекс для следующей итерации\r",
                  "index = (index + 1) % categories.length;\r",
                  "pm.environment.set(\"categoryIndex\", index);\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Статус 200 OK\", function () {\r",
                  "    pm.expect(pm.response.code).to.eql(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Все товары принадлежат выбранной категории\", function () {\r",
                  "    let responseJson = pm.response.json();\r",
                  "    let category = pm.environment.get(\"category\");\r",
                  "\r",
                  "    // Проверяем, что каждый товар имеет поле category равное выбранной категории\r",
                  "    responseJson.forEach(product => {\r",
                  "        pm.expect(product.category).to.eql(category);\r",
                  "    });\r",
                  "});\r",
                  "\r",
                  "// Чистый лог для консоли\r",
                  "console.log(`✅ Категория ${pm.environment.get(\"category\")} проверена`);\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
